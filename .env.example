# ── LLM ──────────────────────────────────────────────
GOOGLE_API_KEY=your_gemini_api_key_here

# ── Database ──────────────────────────────────────────
# Local PostgreSQL (Docker):
DATABASE_URL=postgresql://andavar:andavar@postgres:5432/andavar

# NeonDB (Cloud — replace with your Neon connection string):
# DATABASE_URL=postgresql://user:pass@ep-xxx-yyy.us-east-2.aws.neon.tech/andavar?sslmode=require

# ── App ───────────────────────────────────────────────
ENVIRONMENT=development        # development | production
LOG_LEVEL=INFO
PORT=8000

# ── Security ──────────────────────────────────────────
RATE_LIMIT=30/minute           # requests per IP
SECRET_KEY=change_this_in_prod # used for session signing
CORS_ORIGINS=http://localhost:8000,http://localhost:8001  # comma-separated allowed origins

# ── JWT (REQUIRED in production / multi-worker deployments) ──
# Without this, each worker generates its own secret → tokens become invalid across workers.
# JWT_SECRET=your-strong-random-secret-here

# ── Encryption (REQUIRED in production) ──
# Fernet key for encrypting project credentials. Without this, restarts
# make previously encrypted project database URLs and API keys unrecoverable.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=your-fernet-key-here
